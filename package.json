{
  "name": "opencode-cliproxy-provider",
  "version": "1.0.0",
  "description": "OpenCode plugin that auto-syncs Cliproxy models and thinking levels.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external @opencode-ai/plugin",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "cliproxy",
    "models",
    "auto-sync"
  ],
  "author": "ilseoblee",
  "license": "MIT",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.16.0",
    "bun-types": "1.3.12",
    "typescript": "^5.9.3"
  }
}
