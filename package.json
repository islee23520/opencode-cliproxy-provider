{
  "name": "opencode-cliproxy-provider",
  "version": "1.1.2",
  "description": "OpenCode plugin that auto-syncs Cliproxy models and reasoning levels.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "opencode-cliproxy-provider": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts ./src/cli.ts --outdir ./dist --target bun --format esm --external @opencode-ai/plugin",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "cliproxy",
    "models",
    "reasoning",
    "auto-sync"
  ],
  "author": "ilseoblee <islee23520@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/islee23520/opencode-cliproxy-provider#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/islee23520/opencode-cliproxy-provider.git"
  },
  "bugs": {
    "url": "https://github.com/islee23520/opencode-cliproxy-provider/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.4.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.16.0",
    "bun-types": "1.3.12",
    "typescript": "^5.9.3"
  }
}
